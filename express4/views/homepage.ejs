<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Home Listings</title>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        min-height: 100vh;
        background: linear-gradient(180deg, #f4f6fb 0%, #ffffff 100%);
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: #1f2937;
      }

      .page {
        width: min(96vw, 1140px);
        margin: 0 auto;
        padding: 2rem 1rem 3rem;
      }

      .header {
        display: grid;
        gap: 1rem;
        max-width: 720px;
        margin: 0 auto 2.5rem;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: #4b5563;
      }

      .eyebrow::before {
        content: "";
        width: 0.65rem;
        height: 0.65rem;
        border-radius: 50%;
        background: #2563eb;
      }

      h1 {
        font-size: clamp(2rem, 3.5vw, 3.2rem);
        line-height: 1.05;
      }

      .intro {
        color: #4b5563;
        line-height: 1.75;
        font-size: 1rem;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1.5rem;
      }

      .btn,
      .btn-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.95rem 1.8rem;
        border-radius: 999px;
        font-weight: 700;
        text-decoration: none;
        transition: transform 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
      }

      .btn {
        background: #111827;
        color: #ffffff;
      }

      .btn:hover {
        transform: translateY(-1px);
        background: #1f2937;
      }

      .btn-secondary {
        background: #f8fafc;
        color: #111827;
        border: 1px solid #e2e8f0;
      }

      .btn-secondary:hover {
        background: #eef2ff;
      }

      .listing-count {
        color: #6b7280;
        margin-top: 0.5rem;
        font-size: 0.95rem;
      }

      .listings {
        display: grid;
        gap: 1.5rem;
      }

      .card {
        padding: 1.5rem;
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.95);
        border: 1px solid rgba(146, 166, 211, 0.15);
        box-shadow: 0 18px 45px rgba(15, 23, 42, 0.06);
        display: grid;
        gap: 1rem;
      }

      .card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .name {
        font-size: 1.25rem;
        font-weight: 700;
        color: #111827;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.5rem 0.85rem;
        border-radius: 999px;
        background: #e0f2fe;
        color: #0369a1;
        font-size: 0.87rem;
        font-weight: 700;
      }

      .meta {
        display: grid;
        gap: 0.75rem;
      }

      .meta-item {
        display: flex;
        justify-content: space-between;
        color: #475569;
        font-size: 0.97rem;
      }

      .meta-item span:first-child {
        color: #6b7280;
      }

      .details-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-top: 0.75rem;
        padding: 0.75rem 1.15rem;
        border-radius: 999px;
        background: #2563eb;
        color: #ffffff;
        text-decoration: none;
        font-weight: 700;
        transition: transform 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
        box-shadow: 0 10px 20px rgba(37, 99, 235, 0.18);
      }

      .details-btn:hover {
        transform: translateY(-1px);
        background: #1d4ed8;
        box-shadow: 0 14px 28px rgba(37, 99, 235, 0.22);
      }

      .empty-state {
        padding: 2rem;
        border-radius: 24px;
        background: #eff6ff;
        border: 1px solid #dbeafe;
        color: #1e3a8a;
        text-align: center;
      }

      .empty-state p {
        margin-top: 0.75rem;
        color: #475569;
      }

      @media (min-width: 720px) {
        .listings {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <header class="header">
        <div>
          <span class="eyebrow">Home Listings</span>
          <h1>Browse available homes in a calm, modern layout.</h1>
          <p class="intro">Each listing is easy to scan with name, location, price, and rating. Add new homes quickly from the button below.</p>
          <div class="actions">
            <a href="/add-home" class="btn">Add Home</a>
            <a href="/" class="btn-secondary">Refresh listings</a>
          </div>
          <div class="listing-count"><%= data.length %> listing<%= data.length === 1 ? '' : 's' %> available</div>
        </div>
      </header>

      <% if (data.length === 0) { %>
        <section class="empty-state">
          <h2>No homes yet</h2>
          <p>The listing collection is empty right now. Add your first home to start building the property showcase.</p>
        </section>
      <% } else { %>
        <section class="listings">
          <% data.forEach((home) => { %>
            <article class="card">
              <div class="card-header">
                <div class="name"><%= home.name || 'Untitled home' %></div>
                <span class="badge"><%= home.rating ? `${home.rating}/5` : 'No rating' %></span>
              </div>
              <div class="meta">
                <div class="meta-item"><span>Location</span><span><%= home.location || 'Unknown' %></span></div>
                <div class="meta-item"><span>Price</span><span><%= home.price ? `₹${home.price}` : 'Not set' %></span></div>
              </div>
              <a href="/<%= home.price %>" class="details-btn">Details</a>
            </article>
          <% }) %>
        </section>
      <% } %>
    </div>
  </body>
</html>
